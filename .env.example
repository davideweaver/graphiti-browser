# Xerro API URL
# The xerro-service endpoint (local or remote)
VITE_XERRO_API_URL=https://xerro-mb-api.appkit.net

# Document Navigation
# Comma-separated list of folder names to hide from the documents navigation
VITE_HIDDEN_FOLDERS=.git,Assets,Images,thumbnails,Uncategorized

# System Control Panel

# Llamacpp Admin
# In development: Uses Vite proxy at /llamacpp-admin (set target in vite.config.ts)
# In production: Direct URL to llamacpp admin server
# Example: http://172.16.0.75:9200 or http://localhost:8004
VITE_LLAMACPP_ADMIN_URL=http://localhost:8004

# Bearer token for llamacpp admin authentication
# Get this from llamacpp-cli admin service logs or configuration
# Run: llamacpp admin start --verbose to see the API key
VITE_LLAMACPP_ADMIN_TOKEN=your-bearer-token-here
